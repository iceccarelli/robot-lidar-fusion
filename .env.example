# Robot LiDAR Fusion — Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# --- Control Loop ---
ROBOT_CYCLE_TIME=0.01
ROBOT_TOTAL_MEMORY_BYTES=67108864

# --- Battery ---
ROBOT_BATTERY_CAPACITY_WH=500.0
ROBOT_BATTERY_NOMINAL_VOLTAGE=48.0

# --- Thermal ---
ROBOT_THERMAL_WARNING_C=70.0
ROBOT_THERMAL_CRITICAL_C=85.0

# --- Sensors ---
ROBOT_LIDAR_ENABLED=true
ROBOT_CAMERA_ENABLED=true
ROBOT_LIDAR_MODEL=os1-64
ROBOT_CAMERA_MODEL=realsense-d435

# --- Hazard Thresholds ---
ROBOT_PROXIMITY_WARN_M=1.0
ROBOT_PROXIMITY_STOP_M=0.3

# --- Communication ---
ROBOT_TELEMETRY_ENDPOINT=http://localhost:8080/telemetry
ROBOT_TELEMETRY_INTERVAL_S=1.0

# --- Logging ---
ROBOT_LOG_LEVEL=INFO
ROBOT_LOG_FILE=robot.log
